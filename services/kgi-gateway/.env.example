# KGI Gateway — environment variables
# Copy to .env and fill in real values. NEVER commit .env with real credentials.

# --- KGI credentials (required for login) ---
KGI_PERSON_ID=
KGI_PASSWORD=
KGI_SIMULATION=true

# --- Gateway network ---
KGI_GATEWAY_HOST=0.0.0.0
KGI_GATEWAY_PORT=8765
KGI_GATEWAY_SECRET=

# --- Circuit breakers ---
KGI_GATEWAY_POSITION_DISABLED=false
KGI_GATEWAY_QUOTE_DISABLED=false
