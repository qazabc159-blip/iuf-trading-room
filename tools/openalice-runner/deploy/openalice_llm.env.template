# OpenAlice Runner — LLM backend environment (P0.6)
# NEVER check into git. Owner-only NTFS ACL (prep script enforces).
# Fill values only in the deployed copy at:
#   C:\iuf\secrets\openalice_llm.env
#
# Phase 1: service runs with --llm rule-template; these values may be empty.
# Phase 2: switch_to_openai.ps1 restarts the service with --llm openai after
#          OPENAI_API_KEY is filled (paste only into the on-disk file, never
#          into chat / commit / log / screenshot).

# --- OpenAI (primary external provider) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MODEL_FALLBACK=gpt-4o-mini
OPENAI_MAX_TOKENS=1024
OPENAI_TIMEOUT_MS=30000
# Leave blank unless routing through a proxy / custom endpoint.
OPENAI_BASE_URL=

# --- Kill-switch: set to 1 to force rule-template fallback without stopping the service ---
OPENALICE_LLM_DISABLED=0

# --- Runtime ---
PYTHONUNBUFFERED=1
