# OpenAlice Runner — LLM backend environment (P0.6)
# NEVER check into git. Owner-only NTFS ACL (install script enforces).
# Fill values only in the deployed copy at:
#   C:\iuf\secrets\openalice_llm.env
#
# Phase 1 (today): service runs with --llm rule-template; these values are unused yet.
# Phase 2 (after Elva ships Anthropic adapter): fill ANTHROPIC_API_KEY, then run
#   switch_to_anthropic.ps1 which restarts the service with --llm anthropic.

# --- Anthropic (primary external provider) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TIMEOUT_MS=30000

# --- Future providers (leave blank for now) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=
# OLLAMA_BASE_URL=

# --- Kill-switch: set to 1 to force rule-template fallback without stopping the service ---
OPENALICE_LLM_DISABLED=0

# --- Runtime ---
PYTHONUNBUFFERED=1
