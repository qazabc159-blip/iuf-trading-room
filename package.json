{
  "name": "iuf-trading-room",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "build:packages": "turbo run build --filter=@iuf-trading-room/contracts --filter=@iuf-trading-room/db --filter=@iuf-trading-room/domain --filter=@iuf-trading-room/auth --filter=@iuf-trading-room/ui",
    "build:web": "pnpm run build:packages && pnpm --filter @iuf-trading-room/web build",
    "build:api": "turbo run build --filter=@iuf-trading-room/contracts --filter=@iuf-trading-room/db --filter=@iuf-trading-room/domain --filter=@iuf-trading-room/integrations --filter=@iuf-trading-room/api",
    "build:worker": "turbo run build --filter=@iuf-trading-room/contracts --filter=@iuf-trading-room/db --filter=@iuf-trading-room/domain --filter=@iuf-trading-room/worker",
    "dev": "pnpm run build:packages && turbo run dev --parallel --filter=@iuf-trading-room/api --filter=@iuf-trading-room/worker --filter=@iuf-trading-room/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check:db-execrows": "node ./scripts/check-db-execrows.mjs",
    "test": "node --import ./tests/setup-test-env.mjs --import tsx --test ./tests/ci.test.ts ./tests/risk-persistence.test.ts ./tests/migrate.test.ts ./tests/openalice-orchestrator.test.ts ./apps/api/src/auth/require-min-role.test.ts ./apps/api/src/auth/role-matrix.test.ts ./apps/api/src/broker/broker-account-ownership.test.ts ./apps/api/src/__tests__/ai-rec-perf-execrows.test.ts ./apps/api/src/__tests__/ai-rec-v3-company-name-canonical.test.ts ./apps/api/src/__tests__/ai-rec-v3-contract-aliases.test.ts ./apps/api/src/__tests__/ai-rec-v3-cron-recovery.test.ts ./apps/api/src/__tests__/ai-rec-v3-db-trigger.test.ts ./apps/api/src/__tests__/brief-catchup-manual-fire.test.ts ./apps/api/src/__tests__/brief-dispatcher-schedule.test.ts ./apps/api/src/__tests__/brief-sanitizer-coverage.test.ts ./apps/api/src/__tests__/brief-search.test.ts ./apps/api/src/__tests__/candidate-pool.test.ts ./apps/api/src/__tests__/dashboard-snapshot.test.ts ./apps/api/src/__tests__/factual-reviewer-sourcepack-wire.test.ts ./apps/api/src/__tests__/finmind-aggregate-market.test.ts ./apps/api/src/__tests__/finmind-full-ingest.test.ts ./apps/api/src/__tests__/freshness.test.ts ./apps/api/src/__tests__/heatmap-consistency.test.ts ./apps/api/src/__tests__/heatmap-normalized-merge.test.ts ./apps/api/src/__tests__/kbar.test.ts ./apps/api/src/__tests__/kgi-gateway-schedule.test.ts ./apps/api/src/__tests__/kgi-subscription-manager.test.ts ./apps/api/src/__tests__/lab-strategy-snapshot.test.ts ./apps/api/src/__tests__/llm-gateway-json-mode.test.ts ./apps/api/src/__tests__/migration-0031-dedup.test.ts ./apps/api/src/__tests__/news-ai-selector.test.ts ./apps/api/src/__tests__/openai-multi-scenario.test.ts ./apps/api/src/__tests__/order-intent.test.ts ./apps/api/src/__tests__/paper-four-layer-risk-gate.test.ts ./apps/api/src/__tests__/paper-submit-audit-fields.test.ts ./apps/api/src/__tests__/paper-submit-risk.test.ts ./apps/api/src/__tests__/plans-500-regression.test.ts ./apps/api/src/__tests__/portfolio-snapshot-capture-source.test.ts ./apps/api/src/__tests__/quantity-unit-required.test.ts ./apps/api/src/__tests__/quote-hardening.test.ts ./apps/api/src/__tests__/quote-realtime-wire.test.ts ./apps/api/src/__tests__/radar-live-wire.test.ts ./apps/api/src/__tests__/risk-engine.test.ts ./apps/api/src/__tests__/signal-auto-emitter.test.ts ./apps/api/src/__tests__/stale-data-wave2.test.ts ./apps/api/src/__tests__/strategy-brief.test.ts ./apps/api/src/__tests__/strategy-runs-db.test.ts ./apps/api/src/__tests__/strategy-toggle-mode.test.ts ./apps/api/src/__tests__/symbol-whitelist.test.ts ./apps/api/src/__tests__/theme-refresh.test.ts ./apps/api/src/__tests__/toolcenter-stats-date.test.ts ./apps/api/src/__tests__/weekly-review.test.ts ./apps/api/src/brain/react-loop.test.ts ./apps/api/src/companies-ohlcv.test.ts ./apps/api/src/companies-ticker-resolution.test.ts ./apps/api/src/data-sources/__tests__/discover.test.ts ./apps/api/src/data-sources/__tests__/tw-coverage-loader.test.ts ./apps/api/src/data-sources/finmind-client-latest-raw-fill.test.ts ./apps/api/src/data-sources/finmind-client.test.ts ./apps/api/src/data-sources/twse-mis-quote-client.test.ts ./apps/api/src/domain/trading/paper-ledger-db.test.ts ./apps/api/src/jobs/fundamentals-finmind-sync.test.ts ./apps/api/src/jobs/market-intel-finmind-sync.test.ts ./apps/api/src/jobs/trading-flow-finmind-sync.test.ts ./apps/api/src/jobs/twse-announcement-ingest.test.ts ./apps/api/src/market-data-ohlcv-self-heal.test.ts ./apps/api/src/market-data-overview.test.ts ./apps/api/src/market-ingest.test.ts ./apps/api/src/notification-feed.test.ts ./apps/api/src/openalice-event-rule-engine.test.ts ./apps/api/src/openalice-pipeline.test.ts ./apps/api/src/recommendation-store.test.ts ./apps/api/src/tools/market-data-tools.test.ts ./apps/api/src/weekly-review.test.ts",
    "test:db": "node --import ./tests/setup-test-env.mjs --import tsx --test ./apps/api/src/__tests__/idempotency-race.test.ts ./apps/api/src/__tests__/paper-executor.test.ts ./apps/api/src/__tests__/strategy-ideas.test.ts",
    "qa:playwright": "pnpm --filter @iuf-trading-room/qa-playwright qa:playwright",
    "qa:playwright:smoke": "pnpm --filter @iuf-trading-room/qa-playwright qa:playwright:smoke",
    "smoke": "node --import tsx ./scripts/smoke-api.ts",
    "smoke:autopilot:dryrun": "node --import tsx ./scripts/smoke-autopilot-dryrun.ts",
    "verify:execution": "node --import tsx ./apps/api/src/broker/verify-execution-lane.ts",
    "verify:execution:local": "pnpm verify:execution -- --base http://127.0.0.1:3001 --web-base http://127.0.0.1:3000",
    "verify:execution:live": "pnpm verify:execution -- --base https://api.eycvector.com --web-base https://app.eycvector.com",
    "migrate": "node --import tsx ./scripts/migrate.ts",
    "sync:tw-coverage": "node --import tsx ./scripts/sync-my-tw-coverage-to-production.ts",
    "sync:tw-coverage:graph": "node --import tsx ./scripts/sync-my-tw-coverage-graph-to-production.ts",
    "start:web": "pnpm --filter @iuf-trading-room/web start",
    "start:api": "pnpm --filter @iuf-trading-room/api start",
    "start:worker": "pnpm --filter @iuf-trading-room/worker start",
    "start:api:railway": "node ./scripts/start-api-railway.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "drizzle-kit": "^0.31.5",
    "postgres": "^3.4.7",
    "tsx": "^4.21.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/bcryptjs": "^3.0.0",
    "bcryptjs": "^3.0.3"
  }
}
