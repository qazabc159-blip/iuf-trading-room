NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_WORKSPACE_SLUG=primary-desk
# Risk D mitigation: order-ticket UI gate. Default-false keeps the SUBMIT
# path locked; flip to "true" only when paper trading is formally activated.
NEXT_PUBLIC_IUF_ORDER_UI_ENABLED=false
DATABASE_URL=postgres://postgres:postgres@localhost:5432/iuf_trading_room
PERSISTENCE_MODE=memory
DEFAULT_WORKSPACE_SLUG=primary-desk
REDIS_URL=redis://localhost:6379
WORKER_HEARTBEAT_SECONDS=60
OPENALICE_SWEEP_INTERVAL_SECONDS=60
OPENALICE_DEVICE_STALE_SECONDS=21600
TV_WEBHOOK_TOKEN=replace-with-your-tradingview-secret
TV_WEBHOOK_DEDUP_TTL_SECONDS=300
TV_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
TV_WEBHOOK_RATE_LIMIT_PER_MINUTE=120
TV_WEBHOOK_ENFORCE_TIMESTAMP=false
OPENALICE_DEFAULT_TIMEOUT_SECONDS=900
OPENALICE_MAX_ATTEMPTS=3
# OpenAI API key — used by OpenAlice AI reviewer service (auto-approve content_drafts)
# Never commit a real value; set in Railway env var
OPENAI_API_KEY=
# OpenAlice AI reviewer feature flag — default ON (only "false" disables)
# When enabled, content_drafts are auto-reviewed by gpt-5.4-mini against 7 hard reject rules
OPENALICE_AI_REVIEWER_ENABLED=true
# OpenAI model used by AI reviewer (locked to gpt-5.4-mini per cost cap policy)
# Note: OPENAI_MODEL also serves /api/v1/internal/openalice/hallucination-check endpoint
# (no separate HALLUCINATION_CHECK_MODEL env var needed — both read OPENAI_MODEL)
OPENAI_MODEL=gpt-5.4-mini
# OpenAI model for adversarial (bearish/skeptic) second-pass reviewer — accuracy-priority, 楊董 ACK 2x cost OK
# Default gpt-4.1; override to gpt-4o-mini for cost reduction if needed
OPENAI_ADVERSARIAL_REVIEWER_MODEL=gpt-4.1
# OpenAI model for factual fact-checker (BLOCK #10) — 3rd LLM layer; cross-checks brief claims vs raw FinMind rows
# Runs AFTER hallucination RAG gate; FACTUAL_FALSE → reject, FACTUAL_DRIFT → manual_review
# Default gpt-4.1; est. cost ~$0.005/brief × 30 brief/day ≈ $0.15/day (楊董 ACK 2x cost OK)
OPENAI_FACTUAL_REVIEWER_MODEL=gpt-4.1
# Resend API key for OpenAlice daily email digest (17:00 TST post-close)
# If not set, digest runs in dry-run mode (logs to stdout, no actual email)
RESEND_API_KEY=
# Digest recipient email — set in Railway env var; empty → dry-run mode (no email sent)
DIGEST_EMAIL=
# Resend sender address — default uses Resend's onboarding@resend.dev (works without domain verify)
# After verifying eycvector.com domain in Resend, set to: OpenAlice <noreply@eycvector.com>
DIGEST_FROM=
# FinMind API token (600 req/hr free tier) — set in Railway env var, never commit a real value
FINMIND_API_TOKEN=
# OHLCV source: "mock" (default, no external calls) | "finmind" (live FinMind API)
OHLCV_SOURCE=mock
# Set to "true" to log FinMind sync plan without writing to DB
OHLCV_SYNC_DRY_RUN=false
# Market Agent HMAC secret — shared with services/market-agent, never commit a real value
MARKET_AGENT_HMAC_SECRET=
# Session cookie Domain — set in production when api and web run on different
# sub-domains (e.g. ".eycvector.com" so the cookie is visible to both
# app.eycvector.com SSR and api.eycvector.com fetches). Leave unset in local dev.
AUTH_COOKIE_DOMAIN=
# Sentry DSN — set in Railway env var for error tracking + watchdog alerts.
# DSN is a public endpoint (not a secret), but keep it in env to avoid hard-coding deployment config.
# Empty (default) → Sentry SDK is NOT initialised; all capture*() calls are no-ops.
# Railway operator: copy DSN from Sentry project settings → Client Keys → DSN.
SENTRY_DSN=
# Health watchdog: number of consecutive event-loop lag detections before Sentry alert fires.
# Default 2 (i.e. 2 × 30min = 60min of continuous lag). Adjust if too noisy.
WATCHDOG_FAIL_THRESHOLD=2
# Pipeline scheduler: consecutive fail count before Sentry alert fires (per pipeline phase).
# Default 3 (3 × 15min = 45min of continuous failure). Adjust if too noisy.
PIPELINE_FAIL_THRESHOLD=3
# KGI Windows gateway URL — Path B: gateway runs kgisuperpy on Windows, exposes REST locally.
# Local dev (楊董 desktop): set to http://localhost:8787 when gateway is running.
# Production (Railway): leave unset — gateway is on 楊董 Windows machine, Railway cannot reach it.
#   → /api/v1/companies/:id/quote/realtime returns state=BLOCKED reason=gateway_unreachable (expected).
# Legacy alias: KGI_GATEWAY_BASE_URL (still accepted but KGI_GATEWAY_URL takes precedence).
KGI_GATEWAY_URL=http://localhost:8787
# Paper trading 4-layer risk gate thresholds (PR #296).
# L2: max single-order notional as % of total equity (buy side only).
RISK_MAX_POSITION_PCT=30
# L3: daily loss limit as % of equity; auto-engages kill switch on breach (submit path only).
RISK_DAILY_LOSS_PCT=2
# L4: per-symbol concentration cap as % of equity (buy side only).
RISK_PER_SYMBOL_MAX_PCT=30
