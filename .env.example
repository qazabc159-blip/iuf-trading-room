NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_WORKSPACE_SLUG=primary-desk
# Risk D mitigation: order-ticket UI gate. Default-false keeps the SUBMIT
# path locked; flip to "true" only when paper trading is formally activated.
NEXT_PUBLIC_IUF_ORDER_UI_ENABLED=false
DATABASE_URL=postgres://postgres:postgres@localhost:5432/iuf_trading_room
PERSISTENCE_MODE=memory
DEFAULT_WORKSPACE_SLUG=primary-desk
REDIS_URL=redis://localhost:6379
WORKER_HEARTBEAT_SECONDS=60
OPENALICE_SWEEP_INTERVAL_SECONDS=60
OPENALICE_DEVICE_STALE_SECONDS=21600
TV_WEBHOOK_TOKEN=replace-with-your-tradingview-secret
TV_WEBHOOK_DEDUP_TTL_SECONDS=300
TV_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
TV_WEBHOOK_RATE_LIMIT_PER_MINUTE=120
TV_WEBHOOK_ENFORCE_TIMESTAMP=false
OPENALICE_DEFAULT_TIMEOUT_SECONDS=900
OPENALICE_MAX_ATTEMPTS=3
