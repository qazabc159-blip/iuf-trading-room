{
  "name": "@iuf-trading-room/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm tsx ../../scripts/sync-tw-coverage.ts && tsc -p tsconfig.json && node ../../scripts/write-api-build-metadata.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@iuf-trading-room/contracts": "workspace:*",
    "@iuf-trading-room/db": "workspace:*",
    "@iuf-trading-room/domain": "workspace:*",
    "@iuf-trading-room/integrations": "workspace:*",
    "@sentry/node": "^10.52.0",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.12.8",
    "iconv-lite": "^0.7.2",
    "redis": "^5.9.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/web-push": "^3.6.4",
    "tsx": "^4.21.0"
  }
}
